      "title": "Match Events Timeline",
      "type": "table",
      "targets": [
        {
          "datasource": "Snowflake",
          "queryText": "SELECT e.MINUTE, e.EXTRA_TIME_MINUTE, e.EVENT_TYPE, e.EVENT_DETAIL, e.TEAM_NAME, e.PLAYER_NAME, e.ASSIST_NAME, m.HOME_TEAM, m.AWAY_TEAM, m.HOME_SCORE, m.AWAY_SCORE FROM WC2026.ANALYTICS_ANALYTICS.stg_events e LEFT JOIN WC2026.ANALYTICS_ANALYTICS.fct_match_results m ON e.MATCH_ID = m.MATCH_ID ORDER BY e.MINUTE DESC LIMIT 100;",
          "refId": "A",
          "format": "table"
        }
      ]
